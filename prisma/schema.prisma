// prisma/schema.prisma
// ⚠️  Prisma 7 — connection URLs live in prisma.config.ts, NOT here.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  // No url / directUrl — those moved to prisma.config.ts in Prisma 7
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  INVESTMENT
  CRYPTO_WALLET
  LOAN
  OTHER
}

enum TransactionStatus {
  PENDING
  CLEARED
  RECONCILED
  VOID
  FAILED
}

enum TransactionType {
  DEBIT
  CREDIT
  TRANSFER
}

enum EntryType {
  DEBIT
  CREDIT
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum CurrencyCode {
  USD
  EUR
  GBP
  INR
  BTC
  ETH
  USDC
}

// ─────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String?
  avatarUrl   String?
  timezone    String    @default("UTC")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  accounts    Account[]
  categories  Category[]
  payees      Payee[]
  invoices    Invoice[]
  spendGroups SpendGroup[]
  auditLogs   AuditLog[]

  @@index([email])
  @@map("users")
}

// ─────────────────────────────────────────────
// ACCOUNTS
// ─────────────────────────────────────────────

model Account {
  id               String       @id @default(cuid())
  userId           String
  name             String
  type             AccountType
  currency         CurrencyCode @default(USD)
  currentBalance   Decimal      @default(0) @db.Decimal(20, 8)
  availableBalance Decimal      @default(0) @db.Decimal(20, 8)
  creditLimit      Decimal?     @db.Decimal(20, 8)
  institutionName  String?
  accountNumber    String?
  color            String?
  isActive         Boolean      @default(true)
  isDefault        Boolean      @default(false)
  network          String?
  walletAddress    String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledgerEntries LedgerEntry[]
  fromTransfers Transfer[]    @relation("TransferFrom")
  toTransfers   Transfer[]    @relation("TransferTo")

  @@index([userId])
  @@index([userId, isActive])
  @@map("accounts")
}

// ─────────────────────────────────────────────
// CATEGORIES
// ─────────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  userId    String
  name      String
  icon      String?
  color     String?
  parentId  String?
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent       Category?     @relation("CategoryTree", fields: [parentId], references: [id])
  children     Category[]    @relation("CategoryTree")
  transactions Transaction[]

  @@unique([userId, name])
  @@index([userId])
  @@map("categories")
}

// ─────────────────────────────────────────────
// PAYEES
// ─────────────────────────────────────────────

model Payee {
  id        String   @id @default(cuid())
  userId    String
  name      String
  email     String?
  phone     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  invoices     Invoice[]

  @@unique([userId, name])
  @@index([userId])
  @@map("payees")
}

// ─────────────────────────────────────────────
// TRANSACTIONS
// ─────────────────────────────────────────────

model Transaction {
  id           String            @id @default(cuid())
  userId       String
  categoryId   String?
  payeeId      String?
  description  String
  notes        String?
  amount       Decimal           @db.Decimal(20, 8)
  currency     CurrencyCode      @default(USD)
  type         TransactionType
  status       TransactionStatus @default(CLEARED)
  transactedAt DateTime
  postedAt     DateTime?
  reference    String?
  tags         String[]
  metadata     Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  deletedAt    DateTime?

  category      Category?     @relation(fields: [categoryId], references: [id])
  payee         Payee?        @relation(fields: [payeeId], references: [id])
  ledgerEntries LedgerEntry[]
  invoiceItems  InvoiceItem[]
  attachments   Attachment[]

  @@index([userId])
  @@index([userId, transactedAt])
  @@index([userId, status])
  @@index([userId, categoryId])
  @@map("transactions")
}

// ─────────────────────────────────────────────
// LEDGER ENTRIES
// ─────────────────────────────────────────────

model LedgerEntry {
  id             String       @id @default(cuid())
  transactionId  String
  accountId      String
  entryType      EntryType
  amount         Decimal      @db.Decimal(20, 8)
  currency       CurrencyCode @default(USD)
  runningBalance Decimal      @db.Decimal(20, 8)
  createdAt      DateTime     @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  account     Account     @relation(fields: [accountId], references: [id])

  @@index([transactionId])
  @@index([accountId])
  @@index([accountId, createdAt])
  @@map("ledger_entries")
}

// ─────────────────────────────────────────────
// TRANSFERS
// ─────────────────────────────────────────────

model Transfer {
  id            String            @id @default(cuid())
  fromAccountId String
  toAccountId   String
  amount        Decimal           @db.Decimal(20, 8)
  fee           Decimal           @default(0) @db.Decimal(20, 8)
  fromCurrency  CurrencyCode      @default(USD)
  toCurrency    CurrencyCode      @default(USD)
  exchangeRate  Decimal?          @db.Decimal(20, 8)
  description   String?
  status        TransactionStatus @default(CLEARED)
  transferredAt DateTime
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  fromAccount Account @relation("TransferFrom", fields: [fromAccountId], references: [id])
  toAccount   Account @relation("TransferTo", fields: [toAccountId], references: [id])

  @@index([fromAccountId])
  @@index([toAccountId])
  @@map("transfers")
}

// ─────────────────────────────────────────────
// SPEND GROUPS
// ─────────────────────────────────────────────

model SpendGroup {
  id           String       @id @default(cuid())
  userId       String
  name         String
  description  String?
  budgetAmount Decimal      @db.Decimal(20, 8)
  currency     CurrencyCode @default(USD)
  period       String       @default("monthly")
  color        String?
  icon         String?
  startDate    DateTime     @default(now())
  endDate      DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("spend_groups")
}

// ─────────────────────────────────────────────
// INVOICES
// ─────────────────────────────────────────────

model Invoice {
  id            String        @id @default(cuid())
  userId        String
  payeeId       String?
  invoiceNumber String
  status        InvoiceStatus @default(DRAFT)
  currency      CurrencyCode  @default(USD)
  subtotal      Decimal       @db.Decimal(20, 8)
  taxRate       Decimal       @default(0) @db.Decimal(5, 4)
  taxAmount     Decimal       @default(0) @db.Decimal(20, 8)
  total         Decimal       @db.Decimal(20, 8)
  notes         String?
  dueAt         DateTime
  issuedAt      DateTime      @default(now())
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payee Payee?        @relation(fields: [payeeId], references: [id])
  items InvoiceItem[]

  @@unique([userId, invoiceNumber])
  @@index([userId])
  @@index([userId, status])
  @@map("invoices")
}

model InvoiceItem {
  id            String   @id @default(cuid())
  invoiceId     String
  transactionId String?
  description   String
  quantity      Decimal  @db.Decimal(10, 4)
  unitPrice     Decimal  @db.Decimal(20, 8)
  total         Decimal  @db.Decimal(20, 8)
  sortOrder     Int      @default(0)

  invoice     Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id])

  @@index([invoiceId])
  @@map("invoice_items")
}

// ─────────────────────────────────────────────
// ATTACHMENTS
// ─────────────────────────────────────────────

model Attachment {
  id            String   @id @default(cuid())
  transactionId String
  filename      String
  contentType   String
  url           String
  sizeBytes     Int
  createdAt     DateTime @default(now())

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@map("attachments")
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  tableName String
  recordId  String
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tableName, recordId])
  @@index([createdAt])
  @@map("audit_logs")
}

model DashboardEntry {
  id               String   @id @default(cuid())
  mode             String   @default("web2")
  date             String
  project          String
  earned           Decimal  @default(0) @db.Decimal(20, 8)
  saved            Decimal  @default(0) @db.Decimal(20, 8)
  given            Decimal  @default(0) @db.Decimal(20, 8)
  givenTo          String   @default("")
  walletAddress    String?
  walletName       String?
  investmentAmount Decimal? @db.Decimal(20, 8)
  currentValue     Decimal? @db.Decimal(20, 8)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([mode])
  @@index([date])
  @@map("dashboard_entries")
}

model DashboardGoal {
  id        String   @id @default(cuid())
  mode      String   @unique
  amount    Decimal  @db.Decimal(20, 8)
  currency  String   @default("USD")
  updatedAt DateTime @updatedAt

  @@map("dashboard_goals")
}
