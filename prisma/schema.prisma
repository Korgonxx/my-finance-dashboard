generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String?
  avatarUrl   String?
  timezone    String       @default("UTC")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  passcode    String?      @default("123456")
  accounts    Account[]
  auditLogs   AuditLog[]
  categories  Category[]
  invoices    Invoice[]
  payees      Payee[]
  spendGroups SpendGroup[]

  @@index([email])
  @@map("users")
}

model Account {
  id               String        @id @default(cuid())
  userId           String
  name             String
  type             AccountType
  currency         CurrencyCode  @default(USD)
  currentBalance   Decimal       @default(0) @db.Decimal(20, 8)
  availableBalance Decimal       @default(0) @db.Decimal(20, 8)
  creditLimit      Decimal?      @db.Decimal(20, 8)
  institutionName  String?
  accountNumber    String?
  color            String?
  isActive         Boolean       @default(true)
  isDefault        Boolean       @default(false)
  network          String?
  walletAddress    String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?
  walletMeta       Json?
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledgerEntries    LedgerEntry[]
  fromTransfers    Transfer[]    @relation("TransferFrom")
  toTransfers      Transfer[]    @relation("TransferTo")

  @@index([userId])
  @@index([userId, isActive])
  @@map("accounts")
}

model Category {
  id           String        @id @default(cuid())
  userId       String
  name         String
  icon         String?
  color        String?
  parentId     String?
  isSystem     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  parent       Category?     @relation("CategoryTree", fields: [parentId], references: [id])
  children     Category[]    @relation("CategoryTree")
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, name])
  @@index([userId])
  @@map("categories")
}

model Payee {
  id           String        @id @default(cuid())
  userId       String
  name         String
  email        String?
  phone        String?
  address      String?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  invoices     Invoice[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, name])
  @@index([userId])
  @@map("payees")
}

model Transaction {
  id            String            @id @default(cuid())
  userId        String
  categoryId    String?
  payeeId       String?
  description   String
  notes         String?
  amount        Decimal           @db.Decimal(20, 8)
  currency      CurrencyCode      @default(USD)
  type          TransactionType
  status        TransactionStatus @default(CLEARED)
  transactedAt  DateTime
  postedAt      DateTime?
  reference     String?
  tags          String[]
  metadata      Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?
  attachments   Attachment[]
  invoiceItems  InvoiceItem[]
  ledgerEntries LedgerEntry[]
  category      Category?         @relation(fields: [categoryId], references: [id])
  payee         Payee?            @relation(fields: [payeeId], references: [id])

  @@index([userId])
  @@index([userId, transactedAt])
  @@index([userId, status])
  @@index([userId, categoryId])
  @@map("transactions")
}

model LedgerEntry {
  id             String       @id @default(cuid())
  transactionId  String
  accountId      String
  entryType      EntryType
  amount         Decimal      @db.Decimal(20, 8)
  currency       CurrencyCode @default(USD)
  runningBalance Decimal      @db.Decimal(20, 8)
  createdAt      DateTime     @default(now())
  account        Account      @relation(fields: [accountId], references: [id])
  transaction    Transaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([accountId])
  @@index([accountId, createdAt])
  @@map("ledger_entries")
}

model Transfer {
  id            String            @id @default(cuid())
  fromAccountId String
  toAccountId   String
  amount        Decimal           @db.Decimal(20, 8)
  fee           Decimal           @default(0) @db.Decimal(20, 8)
  fromCurrency  CurrencyCode      @default(USD)
  toCurrency    CurrencyCode      @default(USD)
  exchangeRate  Decimal?          @db.Decimal(20, 8)
  description   String?
  status        TransactionStatus @default(CLEARED)
  transferredAt DateTime
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  fromAccount   Account           @relation("TransferFrom", fields: [fromAccountId], references: [id])
  toAccount     Account           @relation("TransferTo", fields: [toAccountId], references: [id])

  @@index([fromAccountId])
  @@index([toAccountId])
  @@map("transfers")
}

model SpendGroup {
  id           String       @id @default(cuid())
  userId       String
  name         String
  description  String?
  budgetAmount Decimal      @db.Decimal(20, 8)
  currency     CurrencyCode @default(USD)
  period       String       @default("monthly")
  color        String?
  icon         String?
  startDate    DateTime     @default(now())
  endDate      DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("spend_groups")
}

model Invoice {
  id            String        @id @default(cuid())
  userId        String
  payeeId       String?
  invoiceNumber String
  status        InvoiceStatus @default(DRAFT)
  currency      CurrencyCode  @default(USD)
  subtotal      Decimal       @db.Decimal(20, 8)
  taxRate       Decimal       @default(0) @db.Decimal(5, 4)
  taxAmount     Decimal       @default(0) @db.Decimal(20, 8)
  total         Decimal       @db.Decimal(20, 8)
  notes         String?
  dueAt         DateTime
  issuedAt      DateTime      @default(now())
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items         InvoiceItem[]
  payee         Payee?        @relation(fields: [payeeId], references: [id])
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, invoiceNumber])
  @@index([userId])
  @@index([userId, status])
  @@map("invoices")
}

model InvoiceItem {
  id            String       @id @default(cuid())
  invoiceId     String
  transactionId String?
  description   String
  quantity      Decimal      @db.Decimal(10, 4)
  unitPrice     Decimal      @db.Decimal(20, 8)
  total         Decimal      @db.Decimal(20, 8)
  sortOrder     Int          @default(0)
  invoice       Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  @@index([invoiceId])
  @@map("invoice_items")
}

model Attachment {
  id            String      @id @default(cuid())
  transactionId String
  filename      String
  contentType   String
  url           String
  sizeBytes     Int
  createdAt     DateTime    @default(now())
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@map("attachments")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  tableName String
  recordId  String
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tableName, recordId])
  @@index([createdAt])
  @@map("audit_logs")
}

model BanksDashboardEntry {
  id        String   @id(map: "web2_dashboard_entries_pkey") @default(cuid())
  date      String
  project   String
  earned    Decimal  @default(0) @db.Decimal(20, 8)
  saved     Decimal  @default(0) @db.Decimal(20, 8)
  given     Decimal  @default(0) @db.Decimal(20, 8)
  givenTo   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt], map: "web2_dashboard_entries_createdAt_idx")
  @@index([date], map: "web2_dashboard_entries_date_idx")
  @@map("banks_dashboard_entries")
}

model BanksDashboardGoal {
  id        String   @id(map: "web2_dashboard_goal_pkey") @default(cuid())
  amount    Decimal  @db.Decimal(20, 8)
  currency  String   @default("USD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("banks_dashboard_goals")
}

model BanksCard {
  id        String   @id(map: "web2_cards_pkey") @default(cuid())
  name      String
  cardType  String
  lastFour  String
  balance   Decimal  @default(0) @db.Decimal(20, 8)
  currency  String   @default("USD")
  isActive  Boolean  @default(true)
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt], map: "web2_cards_createdAt_idx")
  @@map("banks_cards")
}

model BanksPerformance {
  id        String   @id(map: "web2_performance_pkey") @default(cuid())
  month     String   @unique(map: "web2_performance_month_key")
  earned    Decimal  @default(0) @db.Decimal(20, 8)
  saved     Decimal  @default(0) @db.Decimal(20, 8)
  given     Decimal  @default(0) @db.Decimal(20, 8)
  roi       Decimal  @default(0) @db.Decimal(10, 4)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("banks_performance")
}

model CryptoDashboardEntry {
  id               String   @id(map: "web3_dashboard_entries_pkey") @default(cuid())
  date             String
  project          String
  walletAddress    String
  walletName       String
  network          String
  investmentAmount Decimal  @db.Decimal(20, 8)
  currentValue     Decimal  @db.Decimal(20, 8)
  roi              Decimal  @default(0) @db.Decimal(10, 4)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([createdAt], map: "web3_dashboard_entries_createdAt_idx")
  @@index([date], map: "web3_dashboard_entries_date_idx")
  @@index([walletAddress], map: "web3_dashboard_entries_walletAddress_idx")
  @@map("crypto_dashboard_entries")
}

model CryptoDashboardGoal {
  id        String   @id(map: "web3_dashboard_goal_pkey") @default(cuid())
  amount    Decimal  @db.Decimal(20, 8)
  currency  String   @default("USD")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("crypto_dashboard_goals")
}

model CryptoWalletLegacy {
  id        String   @id(map: "web3_wallets_pkey") @default(cuid())
  name      String   @unique(map: "web3_wallets_name_key")
  address   String   @unique(map: "web3_wallets_address_key")
  network   String
  balance   Decimal  @default(0) @db.Decimal(20, 8)
  currency  String   @default("USD")
  isActive  Boolean  @default(true)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([address], map: "web3_wallets_address_idx")
  @@index([createdAt], map: "web3_wallets_createdAt_idx")
  @@map("crypto_wallets")
}

model CryptoPerformance {
  id              String   @id(map: "web3_performance_pkey") @default(cuid())
  month           String
  walletAddress   String
  investmentTotal Decimal  @default(0) @db.Decimal(20, 8)
  currentTotal    Decimal  @default(0) @db.Decimal(20, 8)
  roi             Decimal  @default(0) @db.Decimal(10, 4)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([month, walletAddress], map: "web3_performance_month_walletAddress_key")
  @@index([month], map: "web3_performance_month_idx")
  @@index([walletAddress], map: "web3_performance_walletAddress_idx")
  @@map("crypto_performance")
}

model DashboardEntry {
  id               String   @id @default(cuid())
  mode             String   @default("web2")
  date             String
  project          String
  earned           Decimal  @default(0) @db.Decimal(20, 8)
  saved            Decimal  @default(0) @db.Decimal(20, 8)
  given            Decimal  @default(0) @db.Decimal(20, 8)
  givenTo          String   @default("")
  walletAddress    String?
  walletName       String?
  investmentAmount Decimal? @db.Decimal(20, 8)
  currentValue     Decimal? @db.Decimal(20, 8)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  walletMeta       Json?

  @@index([mode])
  @@index([date])
  @@map("dashboard_entries")
}

model DashboardGoal {
  id        String   @id @default(cuid())
  mode      String   @unique
  amount    Decimal  @db.Decimal(20, 8)
  currency  String   @default("USD")
  updatedAt DateTime @updatedAt

  @@map("dashboard_goals")
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  INVESTMENT
  CRYPTO_WALLET
  LOAN
  OTHER
}

enum TransactionStatus {
  PENDING
  CLEARED
  RECONCILED
  VOID
  FAILED
}

enum TransactionType {
  DEBIT
  CREDIT
  TRANSFER
}

enum EntryType {
  DEBIT
  CREDIT
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum CurrencyCode {
  USD
  EUR
  GBP
  INR
  BTC
  ETH
  USDC
}
